{
  "$schema": "https://opencode.ai/config.json",
  "enabled_providers": ["bifrost", "azure"],
  "provider": {
    "bifrost": {
      "name": "Bifrost",
      "npm": "@ai-sdk/openai",
      "options": {
        "baseURL": "{env:BIFROST_BASE_URL}"
      },
      "models": {
        "gpt-5.3-codex": {},
        "gpt-5.4": {}
      }
    },
    "azure": {
      "name": "Azure",
      "npm": "@ai-sdk/openai",
      "options": {
        "apiKey": "{env:OPENAI_API_KEY}",
        "baseURL": "{env:OPENAI_BASE_URL}"
      },
      "models": {
        "gpt-5.3-codex": {},
        "gpt-5.4": {}
      }
    }
  },
  "mcp": {
    "alphaxiv": {
      "type": "remote",
      "url": "https://api.alphaxiv.org/mcp/v1",
      "enabled": false
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest"],
      "enabled": false
    },
    "firecrawl-mcp": {
      "type": "local",
      "command": ["npx", "-y", "firecrawl-mcp"],
      "environment": {
        "FIRECRAWL_API_KEY": "{env:FIRECRAWL_API_KEY}"
      },
      "enabled": false
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      },
      "enabled": false
    }
  }
}
